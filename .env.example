# =============================================================================
# Pierflow environment variables.
# Copy to .env.local for development; values are auto-injected on Vercel.
# Never commit a real .env.local — it's gitignored.
# =============================================================================

# -----------------------------------------------------------------------------
# Database (Supabase via Vercel Marketplace)
# -----------------------------------------------------------------------------
# Pooled connection used by the runtime PrismaClient (PgBouncer).
# Vercel injects this as POSTGRES_PRISMA_URL; we read either name.
POSTGRES_PRISMA_URL=

# Direct connection used by Prisma CLI for migrations.
# Vercel injects this as POSTGRES_URL_NON_POOLING; we read either name.
POSTGRES_URL_NON_POOLING=

# Optional: explicit overrides if you'd rather use the canonical names.
# DATABASE_URL=
# DIRECT_URL=

# Supabase project (only used if/when we hit Supabase APIs directly)
SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# -----------------------------------------------------------------------------
# Anthropic (used by the Records API extraction worker)
# Get a key at https://console.anthropic.com/settings/keys.
# Pierflow uses Claude Haiku 4.5 multimodal for paper-to-FHIR extraction.
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=

# -----------------------------------------------------------------------------
# Cloudinary (image storage for scanned pages + import-package archives)
# Sign up at https://cloudinary.com/users/register_free OR install via the
# Vercel Marketplace integration which injects these automatically.
# -----------------------------------------------------------------------------
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# -----------------------------------------------------------------------------
# Clerk (portal auth + machine-to-machine for partners)
# pk_* and sk_* are injected by the Clerk Marketplace integration.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/portal/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/portal/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/portal
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/portal

# -----------------------------------------------------------------------------
# Pierflow Cover — FHIR R4 HIMS (opt-in: leave blank to disable)
# Sign up at https://app.medplum.com/ to get client credentials.
# -----------------------------------------------------------------------------
MEDPLUM_BASE_URL=https://api.medplum.com/
MEDPLUM_CLIENT_ID=
MEDPLUM_CLIENT_SECRET=
MEDPLUM_PROJECT_ID=

# Country profile for Cover (ng = Nigeria, lr = Liberia, sl = Sierra Leone)
COUNTRY_PROFILE=ng

# -----------------------------------------------------------------------------
# Site
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=http://localhost:3000
