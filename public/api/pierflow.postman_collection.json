                ]
              }
            }
          ]
        },
        {
          "name": "Opt out of HMO",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{api_key}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/v1/hmo-providers/{{hmo_slug}}/opt-in",
              "host": ["{{base_url}}"],
              "path": ["v1", "hmo-providers", "{{hmo_slug}}", "opt-in"]
            },
            "description": "Remove opt-in for an HMO. The HMO's plans will no longer appear in GET /v1/plans. In-flight enrollments are unaffected."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('Status is opted_out', () => pm.expect(body.status).to.equal('opted_out'));"
                ]
              }
            }
          ]
