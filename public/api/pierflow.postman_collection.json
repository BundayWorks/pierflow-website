              "path": ["v1", "hmo-providers"]
            },
            "description": "Browse every active HMO on the Pierflow network. Each card shows the published FINTECH rate (what you earn per enrollment) and your current opt-in status.\n\nEnable an HMO via the opt-in endpoint below before its plans appear in GET /v1/plans."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('Has items array', () => pm.expect(body.items).to.be.an('array'));",
                  "if (body.items.length > 0) {",
                  "  pm.collectionVariables.set('hmo_slug', body.items[0].provider_slug);",
                  "  pm.test('First HMO has rate card', () => pm.expect(body.items[0]).to.have.property('lines'));",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Opt in to HMO",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{api_key}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/v1/hmo-providers/{{hmo_slug}}/opt-in",
              "host": ["{{base_url}}"],
              "path": ["v1", "hmo-providers", "{{hmo_slug}}", "opt-in"]
            },
            "description": "Accept the published rate card for this HMO. After this call the HMO's plans appear in GET /v1/plans for your API key.\n\nRate card terms are frozen at acceptance. If Pierflow renegotiates with the HMO, you'll receive an hmo.rate_card.updated webhook."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200 or 201', () => [200, 201].includes(pm.response.code));",
                  "const body = pm.response.json();",
