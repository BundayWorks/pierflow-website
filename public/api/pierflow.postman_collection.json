    {
      "name": "12 · Quotes",
      "description": "Personalised, time-bound quotes. Frozen pricing + rationale for 24 hours. Requires `insurance:read` scope.",
      "item": [
        {
          "name": "Create quote",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"age_in_years\": 28,\n  \"sex\": \"M\",\n  \"dependents\": 0,\n  \"monthly_budget_ngn\": 1000000,\n  \"state\": \"Lagos\",\n  \"lga\": \"Ikeja\",\n  \"limit\": 5,\n  \"fintech_ref\": \"session_pmsmoke_001\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/v1/quotes",
              "host": ["{{base_url}}"],
              "path": ["v1", "quotes"]
            },
            "description": "Submit a minimal user profile, get back ranked + priced quotes. No PII at quote time — BVN/NIN come later at enrollment. Each quote freezes wholesale + markup + member_pays + splits_snapshot so the numbers hold through to settlement."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('Has request_id + quotes array', () => {",
                  "  pm.expect(body).to.have.property('request_id');",
                  "  pm.expect(body.quotes).to.be.an('array');",
                  "});",
                  "pm.collectionVariables.set('quote_request_id', body.request_id);",
                  "if (body.quotes.length > 0) {",
                  "  pm.collectionVariables.set('quote_id', body.quotes[0].id);",
                  "  console.log('quote_id =', body.quotes[0].id, '· score =', body.quotes[0].score);",
                  "  console.log('member_pays_ngn =', body.quotes[0].member_pays_ngn);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Retrieve quote (by quote id)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/v1/quotes/{{quote_id}}",
              "host": ["{{base_url}}"],
              "path": ["v1", "quotes", "{{quote_id}}"]
            },
            "description": "Returns a single ranked quote. Auto-scoped to the calling partner."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('Money fields are strings (BigInt safe)', () => {",
                  "  pm.expect(body.wholesale_ngn).to.be.a('string');",
                  "  pm.expect(body.member_pays_ngn).to.be.a('string');",
                  "});",
                  "pm.test('Rationale present', () => {",
                  "  pm.expect(body.rationale).to.have.property('reasons');",
                  "  pm.expect(body.rationale).to.have.property('warnings');",
                  "  pm.expect(body.rationale).to.have.property('signals');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Retrieve quotes (by request id)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/v1/quotes/{{quote_request_id}}",
              "host": ["{{base_url}}"],
              "path": ["v1", "quotes", "{{quote_request_id}}"]
            },
            "description": "Same endpoint as Retrieve quote, but if the id is a quote-request id you get back the full ranked list instead of one quote."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
