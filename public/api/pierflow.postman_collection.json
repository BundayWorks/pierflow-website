          ]
        }
      ]
    },
    {
      "name": "13 · Enrollments",
      "description": "The binding action — convert a quote into a real HMO policy. Requires `insurance:write` for POSTs, `insurance:read` for GETs.",
      "item": [
        {
          "name": "Create enrollment",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"plan_id\": \"{{plan_id}}\",\n  \"quote_id\": \"{{quote_id}}\",\n  \"fintech_user_ref\": \"{{fintech_user_ref}}\",\n  \"idempotency_key\": \"enr_{{fintech_user_ref}}_v1\",\n  \"identity\": {\n    \"nin\": \"12345678901\",\n    \"full_name\": \"Adaeze Margaret Nwosu\",\n    \"date_of_birth\": \"1985-03-14\",\n    \"sex\": \"F\",\n    \"phone\": \"+2348012345678\"\n  }\n}"
            },
            "url": {
              "raw": "{{base_url}}/v1/enrollments",
              "host": ["{{base_url}}"],
              "path": ["v1", "enrollments"]
            },
            "description": "Submit enrollment intent. Identity is verified inline; the response carries the disposition. PENDING_PAYMENT until you confirm payment received.\n\n**Sandbox magic names:**\n- `TEST_FAIL` in full_name → identity REJECTED\n- `TEST_SOFT` in full_name → identity SOFT_REVIEW\n- anything else → AUTO_APPROVED at 95\n\n**Idempotency:** repeated calls with the same idempotency_key under the same partner return the existing enrollment for 24h."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 202', () => pm.response.to.have.status(202));",
                  "const body = pm.response.json();",
                  "pm.test('Has enrollment + identity', () => {",
                  "  pm.expect(body).to.have.property('enrollment');",
                  "  pm.expect(body).to.have.property('identity');",
                  "});",
                  "pm.collectionVariables.set('enrollment_id', body.enrollment.id);",
                  "console.log('enrollment_id =', body.enrollment.id, '· status =', body.enrollment.status);",
                  "console.log('member_pays_ngn =', body.enrollment.member_pays_ngn);",
                  "console.log('identity:', body.identity.status, body.identity.confidence + '%');"
                ]
              }
            }
          ]
        },
        {
          "name": "Confirm payment received",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount_ngn\": \"1000000\",\n  \"payment_ref\": \"wallet_txn_pmsmoke_001\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/v1/enrollments/{{enrollment_id}}/payment-received",
              "host": ["{{base_url}}"],
              "path": ["v1", "enrollments", "{{enrollment_id}}", "payment-received"]
            },
            "description": "Tell Pierflow you've debited the user's wallet. We advance PENDING_PAYMENT → PENDING_HMO → ACTIVE by calling the HMO connector.\n\n**amount_ngn must exactly equal enrollment.member_pays_ngn.** Update the raw body to match the value from the previous step.\n\nIdempotent — calling twice after ACTIVE returns success without re-charging."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('Enrollment is now ACTIVE', () => pm.expect(body.enrollment.status).to.equal('ACTIVE'));",
                  "pm.test('HMO policy id was issued', () => pm.expect(body.enrollment.hmo_policy_id).to.be.a('string'));",
                  "console.log('hmo_policy_id =', body.enrollment.hmo_policy_id);"
                ]
              }
            }
          ]
        },
        {
          "name": "Retrieve enrollment",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/v1/enrollments/{{enrollment_id}}",
              "host": ["{{base_url}}"],
              "path": ["v1", "enrollments", "{{enrollment_id}}"]
            },
            "description": "Single-enrollment lookup. Auto-scoped to the calling partner."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('Carries the frozen splits snapshot', () => {",
                  "  pm.expect(body.splits_snapshot).to.have.property('lines');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "List enrollments by fintech_user_ref",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/v1/enrollments?fintech_user_ref={{fintech_user_ref}}",
              "host": ["{{base_url}}"],
              "path": ["v1", "enrollments"],
              "query": [
                { "key": "fintech_user_ref", "value": "{{fintech_user_ref}}" }
              ]
            },
            "description": "Show every enrollment for a user across plans + time. Useful for the fintech's 'my policies' surface."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('Returns items array', () => pm.expect(body.items).to.be.an('array'));"
                ]
              }
            }
          ]
        },
        {
          "name": "Cancel enrollment",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reason\": \"user_requested\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/v1/enrollments/{{enrollment_id}}/cancel",
              "host": ["{{base_url}}"],
              "path": ["v1", "enrollments", "{{enrollment_id}}", "cancel"]
            },
            "description": "Terminate the policy. Calls the HMO connector to terminate on their side if a policy was issued. Cannot be undone — re-enrolling requires a fresh POST /v1/enrollments."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('Enrollment now CANCELLED', () => pm.expect(body.enrollment.status).to.equal('CANCELLED'));"
                ]
              }
            }
          ]
        }
      ]
    },
