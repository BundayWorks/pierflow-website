// Pierflow data model.
//
// Nomenclature is deliberately vendor-neutral so the same schema scales
// across any health-industry participant: hospitals, clinics, labs,
// pharmacies, insurers, EMR / HMS / EHR vendors, government programmes.
//
// Core ideas:
//  • Organization is the multi-tenant root (any contracted entity).
//  • Partner is the downstream API consumer; PartnerOrganizationLink
//    gates which organizations a partner can act on.
//  • Patient identifiers live in a separate table so we can hold MRN,
//    BVN, NIN, NHIS, HMO card, passport, etc. without schema churn.
//  • Money is BigInt minor units. Time is ISO-8601 UTC.

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────────────────────────────
// Organizations & sites
// ─────────────────────────────────────────────────────────────────────

enum OrganizationType {
  HOSPITAL
  CLINIC
  LAB
  PHARMACY
  INSURER
  EMR_VENDOR
  HMS_VENDOR
  GOVERNMENT
  COOPERATIVE
  OTHER
}

// Lifecycle for orgs registered through the partner portal.
//   PENDING   — partner submitted; awaiting Pierflow review.
//   ACTIVE    — approved; capture + ingest enabled.
//   REJECTED  — staff declined; partner can edit and resubmit.
//   SUSPENDED — operational pause, distinct from soft-delete.
// Orgs created directly by staff (e.g. the platform org) skip
// PENDING and start ACTIVE.
enum OrgAccessStatus {
  PENDING
  ACTIVE
  REJECTED
  SUSPENDED
}

model Organization {
  id          String           @id @default(cuid())
  name        String
  type        OrganizationType
  // Public-facing slug, optional, used in URLs and references
  slug        String?          @unique
  // Address rolled up to the org if there's only one site
  street      String?
  lga         String?
  state       String?
  country     String           @default("NG")
  // Stable system URI prefix the partner uses for internal patient
  // identifiers. e.g. "https://healthos.ng/mrn/" — combined with the
  // MRN value to namespace identifiers across partners.
  mrnSystem   String?
  // Free-form metadata for fields we haven't formalised
  metadata    Json?
  isActive    Boolean          @default(true)

  // Lifecycle introduced when partners gained the ability to register
  // their own customer orgs through the portal.
  accessStatus           OrgAccessStatus @default(ACTIVE)
  requestedByPartnerId   String?
  requestedByExternalId  String?
  approvedByExternalId   String?
  approvedAt             DateTime?
  rejectionReason        String?
  reviewerNotes          String?         @db.Text

  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  sites               Site[]
  members             OrgMember[]
  partnerLinks        PartnerOrganizationLink[]
  patients            Patient[]
  scanBatches         ScanBatch[]
  processingJobs      ProcessingJob[]
  extractedRecords    ExtractedRecord[]
  importPackages      ImportPackage[]
  approvalEvents      OrganizationApprovalEvent[]
  chartFolders        ChartFolder[]
  mergeCandidates     PatientMergeCandidate[]
  partnerPatientLinks PartnerPatientLink[]
  requestedByPartner  Partner?         @relation("OrgsRequestedByPartner", fields: [requestedByPartnerId], references: [id])

  @@index([type])
  @@index([isActive])
  @@index([accessStatus])
  @@index([requestedByPartnerId])
  @@map("organizations")
}

// Audit trail for every state transition on an Organization. Append
// only; we never edit rows after insertion.
enum OrgApprovalAction {
  REQUESTED
  APPROVED
  REJECTED
  SUSPENDED
  REINSTATED
  EDITED
}

model OrganizationApprovalEvent {
  id             String             @id @default(cuid())
  organizationId String
  action         OrgApprovalAction
  actorExternalId String?           // Clerk user id of the actor (null for system events)
  notes          String?            @db.Text
  detail         Json?              // before/after diff or extra context
  occurredAt     DateTime           @default(now())

  organization   Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, occurredAt])
  @@map("organization_approval_events")
}

model Site {
  id             String       @id @default(cuid())
  organizationId String
  name           String
  street         String?
  lga            String?
  state          String?
  country        String       @default("NG")
  // FHIR Location.position
  latitude       Float?
  longitude      Float?
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  scanBatches    ScanBatch[]

  @@index([organizationId])
  @@map("sites")
}

// ─────────────────────────────────────────────────────────────────────
// Members (humans inside an Organization, authenticated via Clerk)
// ─────────────────────────────────────────────────────────────────────

enum OrgRole {
  OWNER
  ADMIN
  CLINICAL_REVIEWER
  DATA_OFFICER
  CAPTURE_OPERATOR
  VIEWER
}

model OrgMember {
  id             String        @id @default(cuid())
  // External identity provider subject (Clerk user id)
  externalId     String
  organizationId String
  role           OrgRole       @default(VIEWER)
  email          String?
  displayName    String?
  isActive       Boolean       @default(true)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // A single human can hold one role per organization
  @@unique([externalId, organizationId])
  @@index([organizationId])
  @@index([externalId])
  @@map("org_members")
}

// ─────────────────────────────────────────────────────────────────────
// Partners (downstream API consumers — EMR / HMS / payer / etc.)
// ─────────────────────────────────────────────────────────────────────

enum PartnerType {
  EMR_VENDOR
  HMS_VENDOR
  EHR_VENDOR
  INSURER
  GOVERNMENT
  ANALYTICS
  OTHER
}

// Lifecycle of a Partner from sign-up to live access.
//   PENDING_SANDBOX     — signed up, awaiting Pierflow approval to test
//   SANDBOX             — sandbox key issued, can make test calls
//   PRODUCTION_REQUESTED — checklist complete, asked for live access
//   PRODUCTION          — live keys may be issued
//   SUSPENDED           — disabled for cause (kept distinct from isActive)
enum PartnerAccessStatus {
  PENDING_SANDBOX
  SANDBOX
  PRODUCTION_REQUESTED
  PRODUCTION
  SUSPENDED
}

model Partner {
  id          String      @id @default(cuid())
  name        String
  slug        String      @unique
  type        PartnerType
  // Optional public-facing logo / website
  websiteUrl  String?
  isActive    Boolean     @default(true)

  // Onboarding context captured at sign-up — feeds the staff inbox so
  // reviewers can triage without round-tripping the partner.
  primaryUseCase  String?
  expectedVolume  String?
  timeline        String?
  country         String?  @default("NG")

  accessStatus            PartnerAccessStatus @default(PENDING_SANDBOX)
  sandboxApprovedAt       DateTime?
  sandboxApprovedBy       String?  // Clerk user id of approver
  productionRequestedAt   DateTime?
  productionApprovedAt    DateTime?
  productionApprovedBy    String?
  reviewerNotes           String?  @db.Text

  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  apiKeys             PartnerApiKey[]
  organizationLinks   PartnerOrganizationLink[]
  patientLinks        PartnerPatientLink[]
  importPackages      ImportPackage[]
  webhookEndpoints    WebhookEndpoint[]
  users               PartnerUser[]
  profile             PartnerProfile?
  agreements          PartnerAgreement[]
  securityAssessment  PartnerSecurityAssessment?
  requestedOrgs       Organization[] @relation("OrgsRequestedByPartner")

  @@index([accessStatus])
  @@map("partners")
}

// One-to-one profile data the partner completes themselves.
model PartnerProfile {
  partnerId          String   @id
  legalName          String?
  registeredAddress  String?
  contactPhone       String?
  completedAt        DateTime?
  updatedAt          DateTime @updatedAt

  partner            Partner  @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  @@map("partner_profiles")
}

enum AgreementKind {
  DPA
  TOS
}

// Append-only record of click-to-sign agreements. We never overwrite —
// re-signing creates a new row so we can audit history.
model PartnerAgreement {
  id            String        @id @default(cuid())
  partnerId     String
  kind          AgreementKind
  signedAt      DateTime      @default(now())
  signedByExternalId String   // Clerk user id of the signer
  signedByEmail String
  signedByName  String?
  documentVersion String      // e.g. "dpa-2026-06-04"
  ipAddress     String?
  userAgent     String?       @db.Text

  partner       Partner       @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  @@index([partnerId, kind])
  @@map("partner_agreements")
}

// One-to-one security questionnaire. Re-submitting overwrites.
model PartnerSecurityAssessment {
  partnerId           String   @id
  dataResidency       String?  // "ng" | "eu" | "us" | "other"
  retentionDays       Int?
  accessControlNotes  String?  @db.Text
  encryptsAtRest      Boolean  @default(false)
  encryptsInTransit   Boolean  @default(false)
  hasIncidentResponse Boolean  @default(false)
  hasNda              Boolean  @default(false)
  completedAt         DateTime?
  updatedAt           DateTime @updatedAt

  partner             Partner  @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  @@map("partner_security_assessments")
}

// ─────────────────────────────────────────────────────────────────────
// Partner users — humans (Clerk identities) authorised to act on
// behalf of a Partner inside the portal. Created on access-request
// approval and linked to the Clerk user on first sign-in.
// ─────────────────────────────────────────────────────────────────────

enum PartnerUserRole {
  ADMIN
  MEMBER
}

model PartnerUser {
  id          String          @id @default(cuid())
  partnerId   String
  // Clerk user id — set when the invitee actually signs up. Null
  // between "invited" and "first sign-in" so we can pre-authorise.
  externalId  String?         @unique
  email       String
  role        PartnerUserRole @default(ADMIN)
  isActive    Boolean         @default(true)
  invitedAt   DateTime        @default(now())
  joinedAt    DateTime?
  // We track verification ourselves because Clerk's admin-create path
  // marks the email verified by default and Clerk refuses to unverify
  // a user's only/primary email. The dashboard verification widget
  // sets this when the partner enters a 6-digit code we sent them.
  emailVerifiedAt DateTime?

  partner     Partner         @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  @@unique([partnerId, email])
  @@index([partnerId])
  @@index([email])
  @@map("partner_users")
}

model PartnerApiKey {
  id           String    @id @default(cuid())
  partnerId    String
  // Hashed secret — never store the raw key
  keyHash      String    @unique
  // Last 4 of the key for display purposes (e.g. "…f3a1")
  last4        String
  // Human label set by the partner ("prod", "staging", "ci")
  label        String?
  scopes       String[]  @default([])
  revokedAt    DateTime?
  lastUsedAt   DateTime?
  createdAt    DateTime  @default(now())
  expiresAt    DateTime?

  partner      Partner   @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  @@index([partnerId])
  @@map("partner_api_keys")
}

model PartnerOrganizationLink {
  id             String       @id @default(cuid())
  partnerId      String
  organizationId String
  // The package format this partner wants this org's data in
  preferredFormat String      @default("FHIR_R4_JSON")
  createdAt      DateTime     @default(now())

  partner        Partner      @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([partnerId, organizationId])
  @@index([partnerId])
  @@index([organizationId])
  @@map("partner_organization_links")
}

// How a PartnerPatientLink was created — useful for triage when a
// reviewer is looking at a wrong-looking mapping.
enum PartnerPatientLinkSource {
  // Partner posted (mrn, external_id) and we found an existing Patient
  AUTO_MRN
  // Fuzzy-matched name + DOB at link-creation time
  AUTO_FUZZY
  // Partner directly registered the link via /v1/partner-patient-links
  PARTNER_API
  // Reviewer linked via the staff portal
  REVIEWER
  // Partner returned the external id on an import-package acknowledgement
  IMPORT_ACK
  // Created alongside a placeholder Patient when partner posted an
  // unknown MRN
  PLACEHOLDER_FROM_MRN
}

// Bidirectional mapping between Pierflow's Patient id and the
// partner's EMR-side patient id. One row per (partner, our patient)
// and one per (partner, their external id). An EMR vendor querying
// the API with their own customer's patient id can resolve through
// this table to a FHIR Bundle without maintaining their own mapping.
model PartnerPatientLink {
  id                  String                   @id @default(cuid())
  partnerId           String
  patientId           String
  organizationId      String
  // The EMR vendor's identifier for this patient
  externalId          String
  // Optional system URI partners can claim (e.g. https://healthos.ng/patients/).
  // Surfaces in the FHIR Bundle as a third Identifier entry so the
  // partner's EMR can round-trip the link without out-of-band state.
  externalSystem      String?
  source              PartnerPatientLinkSource
  // Auto-match confidence (1.0 for direct partner-supplied links).
  confidence          Float?                   @default(1.0)
  linkedAt            DateTime                 @default(now())
  linkedByExternalId  String?

  partner        Partner       @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  patient        Patient       @relation(fields: [patientId], references: [id], onDelete: Cascade)
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // One mapping per (partner, our patient) — a partner shouldn't have
  // two external ids for the same patient.
  @@unique([partnerId, patientId])
  // One mapping per (partner, their external id) — and the partner
  // shouldn't have two of our patients claiming the same external id.
  @@unique([partnerId, externalId])
  @@index([patientId])
  @@index([organizationId])
  @@map("partner_patient_links")
}

// ─────────────────────────────────────────────────────────────────────
// Patients
// ─────────────────────────────────────────────────────────────────────

enum PatientSex {
  M
  F
  U
}

model Patient {
  id             String       @id @default(cuid())
  organizationId String
  // Cached most-recent display fields. Source of truth lives in
  // ExtractedRecord.fhirBundle for clinical history.
  fullName       String
  dateOfBirth    DateTime?
  sex            PatientSex   @default(U)
  bloodGroup     String?
  genotype       String?
  // Optional "this is probably the same person as …" pointer
  possibleDuplicateOfId String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  organization        Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  possibleDuplicateOf Patient?            @relation("PatientDuplicate", fields: [possibleDuplicateOfId], references: [id])
  possibleDuplicates  Patient[]           @relation("PatientDuplicate")
  identifiers         PatientIdentifier[]
  extractedRecords    ExtractedRecord[]
  declaredCharts      ChartFolder[]       @relation("ChartFolderDeclaredPatient")
  resolvedCharts      ChartFolder[]       @relation("ChartFolderResolvedPatient")
  mergePrimaryOf      PatientMergeCandidate[] @relation("PatientMergeCandidatePrimary")
  mergeCandidateOf    PatientMergeCandidate[] @relation("PatientMergeCandidateCandidate")
  partnerLinks        PartnerPatientLink[]

  @@index([organizationId])
  @@index([fullName])
  @@map("patients")
}

// Candidate "these two Patient rows are probably the same person"
// pair. Written by the duplicate-scoring cron; cleared by a reviewer
// in the Merge queue.
enum MergeDecision {
  PENDING
  MERGE
  KEEP_SEPARATE
}

model PatientMergeCandidate {
  id                  String         @id @default(cuid())
  organizationId      String
  // The canonical (older / higher-confidence) patient
  primaryPatientId    String
  // The likely duplicate of the primary
  candidatePatientId  String
  // 0-1; reviewer typically only sees > 0.5
  score               Float
  // Structured breakdown: { mrn_match, name_similarity, dob_match, … }
  reasons             Json
  detectedAt          DateTime       @default(now())
  reviewerExternalId  String?
  reviewedAt          DateTime?
  decision            MergeDecision  @default(PENDING)
  reviewerNotes       String?        @db.Text

  organization        Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  primaryPatient      Patient        @relation("PatientMergeCandidatePrimary", fields: [primaryPatientId], references: [id], onDelete: Cascade)
  candidatePatient    Patient        @relation("PatientMergeCandidateCandidate", fields: [candidatePatientId], references: [id], onDelete: Cascade)

  // Don't write duplicate rows for the same pair.
  @@unique([primaryPatientId, candidatePatientId])
  @@index([organizationId, decision])
  @@index([decision, detectedAt])
  @@map("patient_merge_candidates")
}

// Extensible identifier table — new ID types are new system URIs,
// not schema migrations.
model PatientIdentifier {
  id        String   @id @default(cuid())
  patientId String
  // Stable system URI: https://pierflow.com/mrn, /bvn, /nin, /nhis, /hmo-card, …
  system    String
  value     String
  // Optional FHIR `Identifier.use` (official, secondary, etc.)
  use       String?
  createdAt DateTime @default(now())

  patient   Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)

  // Same value in the same system, on the same patient, should never duplicate
  @@unique([patientId, system, value])
  @@index([system, value])
  @@map("patient_identifiers")
}

// ─────────────────────────────────────────────────────────────────────
// Records pipeline: ScanBatch → ProcessingJob → ExtractedRecord
// ─────────────────────────────────────────────────────────────────────

enum JobPriority {
  NORMAL
  URGENT
}

enum DocumentType {
  AUTO
  OUTPATIENT_CARD
  REGISTRATION
  LAB_RESULT
  PRESCRIPTION
  ANTENATAL
  IMMUNISATION
  DISCHARGE_SUMMARY
  XRAY_REPORT
  ULTRASOUND_REPORT
  OPERATION_NOTE
  REFERRAL_LETTER
  OTHER
  UNKNOWN
}

enum JobStatus {
  QUEUED
  PROCESSING
  AWAITING_REVIEW
  VALIDATED
  IMPORTED
  FAILED
}

model ScanBatch {
  id             String        @id @default(cuid())
  organizationId String
  siteId         String?
  label          String?
  priority       JobPriority   @default(NORMAL)
  // Clerk user id of the operator who created the batch
  operatorId     String?
  metadata       Json?
  createdAt      DateTime      @default(now())

  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  site           Site?         @relation(fields: [siteId], references: [id])
  jobs           ProcessingJob[]
  chartFolders   ChartFolder[]

  @@index([organizationId])
  @@map("scan_batches")
}

// ─────────────────────────────────────────────────────────────────────
// Chart folders — group pages photographed for one patient's chart so
// identity is resolved at folder level instead of page-by-page.
//
// An operator opens a chart, photographs N pages, then closes the chart
// and moves on. Every ProcessingJob created while the chart is open
// carries `chartFolderId`. After the last job in the folder reaches a
// terminal state, resolveChartFolderIdentity() picks a Patient based on
// (in order): operator declaration, MRN lookup, fuzzy match across the
// folder's extracted evidence, or a new placeholder Patient.
// ─────────────────────────────────────────────────────────────────────

enum ChartFolderResolution {
  // No resolution attempted yet (e.g. jobs still extracting)
  UNRESOLVED
  // Operator picked an existing Patient at capture time
  DECLARED_BY_OPERATOR
  // Operator typed an MRN that matched an existing PatientIdentifier
  MRN_LOOKUP
  // Best-evidence fuzzy match across the folder's ExtractedRecords
  FUZZY_MATCH
  // Created a new Patient (no operator declaration, no MRN match)
  NEW_PATIENT
}

model ChartFolder {
  id                   String   @id @default(cuid())
  batchId              String
  organizationId       String
  // Optional operator-facing label, e.g. "Mrs Adaeze Nwosu"
  label                String?
  // Clerk user id of the operator who created the chart
  operatorId           String?

  // ── Operator-declared identity at capture time. All optional. ──
  declaredPatientId    String?
  // Free-text MRN the operator typed. Resolved against PatientIdentifier
  // during reconciliation.
  declaredMrn          String?
  declaredAt           DateTime @default(now())

  // ── Identity resolved post-extraction. Set by the resolver. ────
  resolvedPatientId    String?
  resolvedAt           DateTime?
  resolvedConfidence   Float?
  resolvedSource       ChartFolderResolution @default(UNRESOLVED)
  // Free-text notes a reviewer may attach (e.g. "merged from chart Y")
  reviewerNotes        String?  @db.Text

  // Counters maintained by capture so we can show progress without
  // a join on every list query.
  pageCount            Int      @default(0)
  // Closed = no new pages will be added. We can still re-resolve.
  closedAt             DateTime?

  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  batch                ScanBatch    @relation(fields: [batchId], references: [id], onDelete: Cascade)
  organization         Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  declaredPatient      Patient?     @relation("ChartFolderDeclaredPatient", fields: [declaredPatientId], references: [id])
  resolvedPatient      Patient?     @relation("ChartFolderResolvedPatient", fields: [resolvedPatientId], references: [id])
  jobs                 ProcessingJob[]

  @@index([batchId])
  @@index([organizationId])
  @@index([resolvedSource])
  @@map("chart_folders")
}

model ProcessingJob {
  id              String        @id @default(cuid())
  batchId         String
  organizationId  String
  // Optional chart this page belongs to. Pages with the same
  // chartFolderId resolve to the same Patient post-extraction.
  // Nullable for backward compat: pre-ChartFolder jobs treat themselves
  // as a single-page chart.
  chartFolderId   String?
  // Object reference in Cloudinary: { publicId, version, format, width, height, bytes }
  sourceAsset     Json
  sourceFilename  String?
  pageCount       Int           @default(1)
  recordTypeHint  DocumentType  @default(AUTO)
  priority        JobPriority   @default(NORMAL)
  status          JobStatus     @default(QUEUED)
  // Idempotency-Key supplied by the caller
  idempotencyKey  String?
  // Free-text reason set when status = FAILED
  errorCode       String?
  errorDetail     String?
  retryCount      Int           @default(0)
  startedAt       DateTime?
  completedAt     DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  batch           ScanBatch       @relation(fields: [batchId], references: [id], onDelete: Cascade)
  organization    Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  chartFolder     ChartFolder?    @relation(fields: [chartFolderId], references: [id], onDelete: SetNull)
  extractedRecords ExtractedRecord[]

  @@unique([organizationId, idempotencyKey])
  @@index([batchId])
  @@index([chartFolderId])
  @@index([organizationId, status])
  @@map("processing_jobs")
}

enum RecordValidationStatus {
  PENDING
  AUTO_APPROVED
  REVIEW_REQUIRED
  VALIDATED
  REJECTED
}

model ExtractedRecord {
  id                   String        @id @default(cuid())
  jobId                String
  organizationId       String
  patientId            String?
  documentType         DocumentType
  pageNumbers          Int[]         @default([])
  // Raw model output: { fields..., _confidence per field, _raw per field }
  extractedJson        Json
  // FHIR R4 Bundle assembled from extractedJson
  fhirBundle           Json?
  completenessScore    Float?
  avgConfidence        Float?
  lowConfidenceFields  Json?
  validationStatus     RecordValidationStatus @default(PENDING)
  // Clerk user id of reviewer + timestamp + notes
  reviewerExternalId   String?
  reviewedAt           DateTime?
  reviewerNotes        String?
  importPackageId      String?
  importedAt           DateTime?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  job                  ProcessingJob  @relation(fields: [jobId], references: [id], onDelete: Cascade)
  organization         Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  patient              Patient?       @relation(fields: [patientId], references: [id])
  importPackage        ImportPackage? @relation(fields: [importPackageId], references: [id])

  @@index([organizationId, validationStatus])
  @@index([jobId])
  @@index([patientId])
  @@map("extracted_records")
}

// ─────────────────────────────────────────────────────────────────────
// Import packages (consumed by Partners)
// ─────────────────────────────────────────────────────────────────────

enum ImportPackageStatus {
  BUILDING
  READY
  ACKNOWLEDGED
  EXPIRED
}

model ImportPackage {
  id              String              @id @default(cuid())
  organizationId  String
  partnerId       String
  status          ImportPackageStatus @default(BUILDING)
  patientCount    Int                 @default(0)
  recordCount     Int                 @default(0)
  // Cloudinary asset for the assembled ZIP
  archiveAsset    Json?
  fileSizeBytes   BigInt?
  checksumSha256  String?
  createdAt       DateTime            @default(now())
  expiresAt       DateTime?
  acknowledgedAt  DateTime?
  ackImportedCount Int?
  ackFailedCount   Int?
  ackPayload      Json?
  updatedAt       DateTime            @updatedAt

  organization     Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  partner          Partner           @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  extractedRecords ExtractedRecord[]

  @@index([partnerId, status])
  @@index([organizationId, status])
  @@map("import_packages")
}

// ─────────────────────────────────────────────────────────────────────
// Webhooks (kept for shape; delivery wired in a later step)
// ─────────────────────────────────────────────────────────────────────

model WebhookEndpoint {
  id          String   @id @default(cuid())
  partnerId   String
  url         String
  events      String[] @default([])
  // Per-endpoint HMAC signing secret. Stored encrypted at rest by
  // Supabase's column-level encryption; we never expose it back to
  // the partner — they can rotate but not re-read. Despite the legacy
  // column name ("secretHash"), this holds the raw signing key — HMAC
  // would not work with a one-way hash.
  secretHash  String
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  partner     Partner  @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  @@index([partnerId])
  @@map("webhook_endpoints")
}

// ─────────────────────────────────────────────────────────────────────
// Audit log (append-only via DB policy added in a SQL migration)
// ─────────────────────────────────────────────────────────────────────

enum AuditAction {
  CREATE
  READ
  UPDATE
  DELETE
  EXPORT
  IMPORT
  LOGIN
  LOGOUT
}

model AuditLog {
  id              String       @id @default(cuid())
  occurredAt      DateTime     @default(now())
  // Actor: either an org_member (Clerk subject) or a partner_api_key id
  actorType       String       // "member" | "partner_api_key" | "system"
  actorId         String?
  organizationId  String?
  partnerId       String?
  action          AuditAction
  resourceType    String       // "patient" | "extracted_record" | …
  resourceId      String?
  ipAddress       String?
  userAgent       String?
  // Anything else worth keeping: request id, before/after diff hashes, …
  detail          Json?

  @@index([occurredAt])
  @@index([organizationId, occurredAt])
  @@index([partnerId, occurredAt])
  @@index([actorType, actorId])
  @@map("audit_log")
}
